# Feedling Caddyfile
# Place at /etc/caddy/Caddyfile on the VPS (self-hosted users: s/feedling.app/<your-domain>/).
# Caddy auto-provisions Let's Encrypt certs on first reload — make sure DNS
# for both hostnames points at this VPS before starting.

# MCP server — Claude.ai / Claude Desktop connect here over SSE.
# Phase C.2: traffic is proxied to the Phala CVM MCP service (port 5002),
# which holds a Let's Encrypt cert for mcp.feedling.app generated inside
# the TDX enclave.
#
# SNI quirk: Phala's dstack-gateway routes connections by SNI and only
# accepts its own `-PORTs.*.phala.network` hostname. If we set
# `tls_server_name mcp.feedling.app`, the gateway drops the TCP
# connection before the TLS handshake reaches the CVM. So we send the
# gateway hostname as SNI and skip upstream cert verification — the
# real trust root is the attestation at /attestation (port 5003), which
# iOS and `tools/audit_live_cvm.py` pin independently (Row 8 proves the
# LE cert's pubkey is bound to the TDX enclave).
#
# NOTE: update the upstream URL after every CVM redeploy (the hash
# prefix changes). Current CVM: 051a174f2457a6c474680a5d745372398f97b6ad
mcp.feedling.app {
    reverse_proxy https://051a174f2457a6c474680a5d745372398f97b6ad-5002s.dstack-pha-prod5.phala.network {
        transport http {
            tls_server_name 051a174f2457a6c474680a5d745372398f97b6ad-5002s.dstack-pha-prod5.phala.network
            tls_insecure_skip_verify
        }
    }
}

# iOS app API — mobile client + HTTP skill agents connect here.
api.feedling.app {
    # Increase read timeout so /v1/chat/poll long-poll (up to 60s) doesn't get cut.
    reverse_proxy localhost:5001 {
        transport http {
            response_header_timeout 90s
        }
    }
}
