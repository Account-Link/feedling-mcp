# Feedling — backend + MCP server container image.
#
# One image, two entrypoints (CMD-selected) for the Flask HTTP API and the
# FastMCP SSE server. Non-root, minimal, stateless — state lives in the
# mounted /data volume.
#
# Reproducibility (Phase 1 goal — see docs/DESIGN_E2E.md):
#  - Base image pinned by sha256 digest.
#  - pip deps pinned + hash-verified via requirements.lock (generated by
#    `uv pip compile backend/requirements.txt --generate-hashes`).
#  - System apt packages are the only remaining source of non-determinism;
#    acceptable for Phase 1 and locked down further later if auditors ask.
#
# To upgrade either pin, regenerate and commit both the new digest and the
# new requirements.lock in the same PR. Docs/BUILD.md has the exact steps.

ARG PYTHON_IMAGE=python@sha256:9e01bf1ae5db7649a236da7be1e94ffbbbdd7a93f867dd0d8d5720d9e1f89fab
FROM ${PYTHON_IMAGE} AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    FEEDLING_DATA_DIR=/data

WORKDIR /app

# System deps for wheels that compile from source (cryptography, pynacl, …).
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        build-essential \
        libssl-dev \
        libffi-dev \
        curl \
 && rm -rf /var/lib/apt/lists/*

# Hash-verified install. `--require-hashes` fails the build if any package
# drifts from the lockfile, preventing supply-chain swaps at build time.
COPY backend/requirements.lock ./requirements.lock
RUN pip install --require-hashes -r requirements.lock

COPY backend/ ./backend/

# Run as a fixed non-root UID so bind-mounted volumes on the host can be
# chowned predictably.
RUN useradd --system --uid 1000 --home-dir /home/feedling --create-home feedling \
 && mkdir -p /data \
 && chown -R feedling:feedling /data /app
USER feedling

EXPOSE 5001 5002 9998

# Default command runs the Flask backend. docker-compose overrides for the
# MCP service.
CMD ["python", "-u", "backend/app.py"]
