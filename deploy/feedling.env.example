# Copy to /home/ubuntu/feedling.env and fill in real values
# Do NOT commit the real feedling.env to git

FEEDLING_API_KEY=change-me
FEEDLING_DATA_DIR=/home/ubuntu/feedling-data
FEEDLING_PUBLIC_BASE_URL=https://api.feedling.app
FEEDLING_FLASK_URL=http://127.0.0.1:5001
FEEDLING_MCP_PORT=5002

# APNs (copy from existing setup)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=/home/ubuntu/feedling-data/apns.p8
BUNDLE_ID=
