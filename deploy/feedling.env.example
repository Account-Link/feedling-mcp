# Copy to /home/ubuntu/feedling.env and fill in real values
# Do NOT commit the real feedling.env to git

# -------- deployment mode --------
# SINGLE_USER=true  → self-hosted: flat ~/feedling-data layout, one shared key
# SINGLE_USER=false → multi-tenant: per-user dirs, iOS app registers for a key
SINGLE_USER=true

# -------- shared key (single-user only) --------
# Generate with: openssl rand -hex 32
# In SINGLE_USER=true mode:
#   if FEEDLING_API_KEY is set, every request must send X-API-Key matching it
#   if FEEDLING_API_KEY is empty, the backend skips auth entirely
FEEDLING_API_KEY=change-me

# -------- storage + networking --------
FEEDLING_DATA_DIR=/home/ubuntu/feedling-data
FEEDLING_PUBLIC_BASE_URL=https://api.feedling.app
FEEDLING_FLASK_URL=http://127.0.0.1:5001
FEEDLING_MCP_PORT=5002
FEEDLING_MCP_TRANSPORT=sse

# -------- APNs (copy from existing setup) --------
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=/home/ubuntu/feedling-data/apns.p8
BUNDLE_ID=
